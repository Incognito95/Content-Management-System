<%- include ./partials/sidebar %>

<script src="https://cdn.ckeditor.com/ckeditor5/18.0.0/classic/ckeditor.js"></script>

<div class="container">
    <h3>Add New Blog Post</h3>
    <hr>
    <span style="color: green"><%= typeof messages !== "undefined" && typeof messages.info !== "undefined" ? messages.info : "" %></span>
    <form action="/create" method="post">
        <fieldset>
            <label for="">Author</label>
            <input type="text" class="form-control" name="author">
        </fieldset>
        <fieldset>
            <label for="">Title</label>
            <input type="text" class="form-control" name="title">
        </fieldset>
        <fieldset>
            <label for="">Description</label>
            <textarea id="editor" rows="10" class="form-control" name="description"></textarea>
        </fieldset>
        <fieldset>
            <label for="">Date</label>
            <input type="text" class="form-control" name="date">
        </fieldset>
        <button type="submit" class="btn btn-success btn-post pull-right">Post</button>
    </form>
</div>

<script>
    ClassicEditor
        .create(document.querySelector('#editor'))
        .then(editor => {
            console.log(editor);
        })
        .catch(error => {
            console.error(error);
        });
</script>

